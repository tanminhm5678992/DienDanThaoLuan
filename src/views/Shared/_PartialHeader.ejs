<link
    href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap"
    rel="stylesheet">

<style>
    :root {
        --bg-primary: #0b0f1a;
        --bg-secondary: #111827;
        --bg-card: #161d2e;
        --border: rgba(99, 179, 237, 0.12);
        --accent: #63b3ed;
        --accent2: #68d391;
        --accent3: #f6ad55;
        --text-primary: #e2e8f0;
        --text-muted: #718096;
        --mono: 'Space Mono', monospace;
        --sans: 'DM Sans', sans-serif;
    }

    /* ── Light theme ── */
    body.light-theme {
        --bg-primary: #f0f4f8;
        --bg-secondary: #ffffff;
        --bg-card: #ffffff;
        --border: rgba(99, 179, 237, 0.2);
        --accent: #2b7ab8;
        --accent2: #276749;
        --accent3: #b7791f;
        --text-primary: #1a202c;
        --text-muted: #4a5568;
    }

    body.light-theme #menu {
        background: #f7fafc;
    }

    body.light-theme .snowflake {
        color: rgba(0, 0, 0, 0.08);
    }

    /* Transition mượt khi đổi theme */
    *,
    *::before,
    *::after {
        transition: background-color 0.25s ease, border-color 0.25s ease, color 0.15s ease;
    }

    /* Tắt transition cho animation cụ thể */
    .bell-btn i,
    .brand-name::before {
        transition: none !important;
    }

    /* ── Theme toggle button ── */
    .theme-btn {
        position: relative;
        background: rgba(99, 179, 237, 0.08);
        border: 1px solid var(--border);
        color: var(--text-muted);
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 1rem;
    }

    .theme-btn:hover {
        background: rgba(99, 179, 237, 0.18);
        color: var(--accent);
        border-color: var(--accent);
        transform: translateY(-1px);
    }

    /* Icon rotate khi đổi theme */
    .theme-btn i {
        transition: transform 0.4s ease, opacity 0.2s ease !important;
    }

    .theme-btn.spinning i {
        transform: rotate(180deg);
    }

    body {
        background: var(--bg-primary);
        color: var(--text-primary);
        font-family: var(--sans);
    }

    /* ── Header ── */
    #header {
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 200;
        backdrop-filter: blur(12px);
    }

    .brand-name {
        font-family: var(--mono);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--accent);
        text-decoration: none;
        letter-spacing: -0.5px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .brand-name::before {
        content: '>';
        color: var(--accent2);
        font-size: 1rem;
        animation: blink 1.2s step-end infinite;
    }

    @keyframes blink {

        0%,
        100% {
            opacity: 1
        }

        50% {
            opacity: 0
        }
    }

    /* ── Bell icon ── */
    .bell-btn {
        position: relative;
        background: rgba(99, 179, 237, 0.08);
        border: 1px solid var(--border);
        color: var(--text-muted);
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.2s;
        font-size: 1.05rem;
    }

    .bell-btn:hover {
        background: rgba(99, 179, 237, 0.18);
        color: var(--accent);
        border-color: var(--accent);
        transform: translateY(-1px);
    }

    .bell-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        background: #fc4e4e;
        color: #fff;
        font-size: 0.6rem;
        font-weight: 700;
        min-width: 16px;
        height: 16px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 3px;
        font-family: var(--mono);
        border: 2px solid var(--bg-secondary);
    }

    .bell-btn.has-notif {
        color: var(--accent);
    }

    .bell-btn.has-notif i {
        animation: bellRing 2s ease-in-out infinite;
    }

    @keyframes bellRing {

        0%,
        90%,
        100% {
            transform: rotate(0);
        }

        92% {
            transform: rotate(-15deg);
        }

        94% {
            transform: rotate(15deg);
        }

        96% {
            transform: rotate(-10deg);
        }

        98% {
            transform: rotate(10deg);
        }
    }

    /* ── User dropdown ── */
    .user-btn {
        background: rgba(99, 179, 237, 0.08);
        border: 1px solid var(--border);
        color: var(--text-primary);
        padding: 0.4rem 0.9rem;
        border-radius: 10px;
        font-size: 0.84rem;
        font-family: var(--sans);
        font-weight: 500;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .user-btn:hover,
    .user-btn:focus {
        background: rgba(99, 179, 237, 0.15);
        border-color: rgba(99, 179, 237, 0.4);
        color: var(--text-primary);
    }

    .user-avatar {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        font-weight: 700;
        color: #0b0f1a;
        flex-shrink: 0;
    }

    .user-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 6px;
    }

    .hd-dropdown .dropdown-menu {
        background: #1a2235;
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6);
        padding: 6px;
        min-width: 200px;
    }

    .hd-dropdown .dropdown-item {
        color: var(--text-muted);
        font-size: 0.84rem;
        padding: 0.5rem 0.8rem;
        border-radius: 8px;
        transition: all 0.15s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .hd-dropdown .dropdown-item:hover {
        background: rgba(99, 179, 237, 0.1);
        color: var(--accent);
    }

    .hd-dropdown .dropdown-item.text-danger:hover {
        background: rgba(252, 78, 78, 0.1);
        color: #fc4e4e;
    }

    .hd-dropdown .dropdown-divider {
        border-color: var(--border);
        margin: 4px 0;
    }

    /* ── Auth buttons ── */
    .btn-login {
        background: var(--accent);
        color: #0b0f1a;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-size: 0.84rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-login:hover {
        background: #90cdf4;
        color: #0b0f1a;
        transform: translateY(-1px);
    }

    .btn-register {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-muted);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-size: 0.84rem;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-register:hover {
        border-color: var(--accent);
        color: var(--accent);
    }
</style>

<div id="header">
    <div class="container">
        <header class="d-flex justify-content-between align-items-center py-2">
            <!-- Logo -->
            <a href="/" class="brand-name">IT Xperience</a>

            <!-- Right side -->
            <div class="d-flex align-items-center gap-2">
                <!-- 🌙 / ☀️ Theme toggle -->
                <button class="theme-btn" id="themeBtn" onclick="toggleTheme()" title="Đổi giao diện">
                    <i class="fas fa-moon" id="themeIcon"></i>
                </button>

                <% if (locals.userId || locals.adminId) { %>

                    <!-- 🔔 Chuông thông báo -->
                    <a href="/thong-bao" class="bell-btn <%= (locals.unreadCount > 0) ? 'has-notif' : '' %>"
                        title="Thông báo">
                        <i class="fas fa-bell"></i>
                        <% if (locals.unreadCount> 0) { %>
                            <span class="bell-badge">
                                <%= unreadCount> 99 ? '99+' : unreadCount %>
                            </span>
                            <% } %>
                    </a>

                    <!-- User dropdown -->
                    <div class="dropdown hd-dropdown">
                        <button class="user-btn dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <span class="user-avatar">
                                <% if (locals.userAvatar) { %><span class="user-avatar"><img
                                            src="/Images/<%= locals.userAvatar %>" alt="Avatar"
                                            onerror="this.onerror=null;this.src='/Images/avatar.jpg';">
                                    </span>
                                    <% } else { %><span class="user-avatar">
                                            <%= (locals.username || 'U' ).charAt(0).toUpperCase() %>
                                        </span>
                                        <% } %>
                            </span>
                            <%= locals.username || 'Người dùng' %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/user-info">
                                    <i class="fas fa-user-circle"></i> Thông tin cá nhân
                                </a></li>
                            <li><a class="dropdown-item" href="/bai-viet-cua-toi">
                                    <i class="fas fa-file-alt"></i> Bài viết của tôi
                                </a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item text-danger" href="/account/logout">
                                    <i class="fas fa-sign-out-alt"></i> Đăng xuất
                                </a></li>
                        </ul>
                    </div>

                    <% } else { %>
                        <a href="/account/login" class="btn-login">Đăng nhập</a>
                        <a href="/account/register" class="btn-register">Đăng ký</a>
                        <% } %>
            </div>
        </header>
    </div>
</div>

<script>
    (function () {
        // Áp dụng theme đã lưu ngay khi load (tránh flash)
        var saved = localStorage.getItem('itx-theme') || 'dark';
        if (saved === 'light') {
            document.body.classList.add('light-theme');
            var icon = document.getElementById('themeIcon');
            if (icon) { icon.classList.remove('fa-moon'); icon.classList.add('fa-sun'); }
        }
    })();

    function toggleTheme() {
        var btn = document.getElementById('themeBtn');
        var icon = document.getElementById('themeIcon');
        var isLight = document.body.classList.toggle('light-theme');

        // Animate icon
        btn.classList.add('spinning');
        setTimeout(function () { btn.classList.remove('spinning'); }, 400);

        if (isLight) {
            icon.classList.remove('fa-moon');
            icon.classList.add('fa-sun');
            localStorage.setItem('itx-theme', 'light');
        } else {
            icon.classList.remove('fa-sun');
            icon.classList.add('fa-moon');
            localStorage.setItem('itx-theme', 'dark');
        }
    }
</script>