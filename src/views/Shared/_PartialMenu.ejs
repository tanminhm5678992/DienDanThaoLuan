<style>
    #menu {
        background: #0d1422;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 57px;
        z-index: 190;
    }

    #menu .nav-link {
        color: var(--text-muted) !important;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        padding: 0.72rem 1rem !important;
        font-family: var(--mono);
        transition: color 0.2s;
        position: relative;
        text-transform: uppercase;
    }

    #menu .nav-link:hover,
    #menu .nav-link.active {
        color: var(--accent) !important;
    }

    #menu .nav-link.active::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 1rem;
        right: 1rem;
        height: 2px;
        background: linear-gradient(90deg, var(--accent), var(--accent2));
        border-radius: 2px;
    }

    /* tag icon trước nav item */
    #menu .nav-link i {
        font-size: 0.75rem;
        margin-right: 5px;
        opacity: 0.7;
    }

    #menu .dropdown-menu {
        background: #1a2235;
        border: 1px solid var(--border);
        border-radius: 10px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.6);
        padding: 6px;
        margin-top: 0 !important;
    }

    #menu .dropdown-item {
        color: var(--text-muted);
        font-size: 0.82rem;
        padding: 0.45rem 0.85rem;
        border-radius: 7px;
        font-family: var(--sans);
        transition: all 0.15s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    #menu .dropdown-item::before {
        content: '#';
        color: var(--accent2);
        font-weight: 700;
        font-size: 0.75rem;
    }

    #menu .dropdown-item:hover {
        background: rgba(99, 179, 237, 0.1);
        color: var(--accent);
    }

    #menu .nav-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #fc4e4e;
        color: #fff;
        font-size: 0.58rem;
        font-weight: 700;
        min-width: 15px;
        height: 15px;
        border-radius: 8px;
        padding: 0 3px;
        margin-left: 4px;
        font-family: var(--mono);
        vertical-align: middle;
    }

    /* Run Code đặc biệt */
    #menu .nav-link.nav-runcode {
        color: var(--accent2) !important;
        border: 1px solid rgba(104, 211, 145, 0.2);
        border-radius: 7px;
        margin: 8px 4px;
        padding: 0.4rem 0.85rem !important;
    }

    #menu .nav-link.nav-runcode:hover {
        background: rgba(104, 211, 145, 0.1);
        border-color: var(--accent2);
    }

    #menu .nav-link.nav-runcode::after {
        display: none;
    }
</style>

<div id="menu">
    <div class="container">
        <nav class="navbar navbar-expand-lg p-0">
            <button class="navbar-toggler my-1" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                style="border-color:rgba(99,179,237,0.3); padding:4px 8px;">
                <i class="fas fa-bars" style="color:var(--accent);font-size:0.85rem;"></i>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto align-items-lg-center">

                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home"></i>Trang chủ</a>
                    </li>

                    <!-- Chủ đề -->
                    <% if (locals.loaiCDs && loaiCDs.length> 0) { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-layer-group"></i>Chủ đề
                            </a>
                            <ul class="dropdown-menu">
                                <% loaiCDs.forEach(function(cd) { %>
                                    <li><a class="dropdown-item" href="/chu-de/<%= cd.MaLoai %>">
                                            <%= cd.TenLoai %>
                                        </a></li>
                                    <% }); %>
                            </ul>
                        </li>
                        <% } %>

                            <li class="nav-item">
                                <a class="nav-link" href="/bai-viet-moi"><i class="fas fa-fire-alt"></i>Bài viết mới</a>
                            </li>

                            <!-- Góp ý -->
                            <% if (locals.adminId) { %>
                                <li class="nav-item">
                                    <a class="nav-link" href="/admin/gop-y">
                                        <i class="fas fa-comment-dots"></i>Góp ý
                                        <% if (locals.soLuongGopY> 0) { %>
                                            <span class="nav-badge">
                                                <%= soLuongGopY %>
                                            </span>
                                            <% } %>
                                    </a>
                                </li>
                                <% } else if (locals.userId) { %>
                                    <li class="nav-item">
                                        <a class="nav-link" href="/gop-y"><i class="fas fa-comment-dots"></i>Góp ý</a>
                                    </li>
                                    <% } %>

                                        <!-- Run Code -->
                                        <li class="nav-item">
                                            <a class="nav-link nav-runcode" href="/code/execution-result">
                                                <i class="fas fa-play-circle"></i>Run Code
                                            </a>
                                        </li>

                                        <!-- Separator admin -->
                                        <% if (locals.adminId) { %>
                                            <li class="nav-item">
                                                <a class="nav-link" href="/admin/duyet-bai">
                                                    <i class="fas fa-check-circle"></i>Duyệt bài
                                                    <% if (locals.soLuongBaiViet> 0) { %>
                                                        <span class="nav-badge">
                                                            <%= soLuongBaiViet %>
                                                        </span>
                                                        <% } %>
                                                </a>
                                            </li>
                                            <li class="nav-item dropdown">
                                                <a class="nav-link dropdown-toggle" href="#" role="button"
                                                    data-bs-toggle="dropdown">
                                                    <i class="fas fa-cog"></i>Quản lý
                                                </a>
                                                <ul class="dropdown-menu">
                                                    <li><a class="dropdown-item" href="/admin/quan-ly/loai-chu-de">Loại
                                                            chủ đề</a></li>
                                                    <li><a class="dropdown-item" href="/admin/quan-ly/chu-de">Chủ đề</a>
                                                    </li>
                                                    <li><a class="dropdown-item" href="/admin/quan-ly-thanh-vien">Thành
                                                            viên</a></li>
                                                    <li><a class="dropdown-item" href="/admin/thong-bao-tong">Thông báo
                                                            tổng</a></li>
                                                </ul>
                                            </li>
                                            <% } %>
                </ul>
            </div>
        </nav>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const path = window.location.pathname;
        document.querySelectorAll('#menu .nav-link').forEach(link => {
            try {
                if (link.classList.contains('dropdown-toggle')) {
                    const items = link.closest('li').querySelectorAll('.dropdown-item');
                    items.forEach(item => {
                        if (new URL(item.href).pathname === path) link.classList.add('active');
                    });
                    return;
                }
                if (new URL(link.href).pathname === path) link.classList.add('active');
            } catch (e) { }
        });
    });
</script>