<h2 class="execution-title mt-3">Run Code</h2>

<!-- Chọn ngôn ngữ lập trình -->
<div class="language-container">
    <label for="languageSelect" class="language-label">Chọn ngôn ngữ lập trình:</label>
    <select id="languageSelect" class="form-control mt-2" name="language" onchange="toggleInput()">
        <option value="python" <%=locals.SelectedLanguage==='python' ? 'selected' : '' %>>Python</option>
        <option value="java" <%=locals.SelectedLanguage==='java' ? 'selected' : '' %>>Java</option>
        <option value="php" <%=locals.SelectedLanguage==='php' ? 'selected' : '' %>>PHP</option>
        <option value="c" <%=locals.SelectedLanguage==='c' ? 'selected' : '' %>>C</option>
        <option value="cpp" <%=locals.SelectedLanguage==='cpp' ? 'selected' : '' %>>C++</option>
        <option value="javascript" <%=locals.SelectedLanguage==='javascript' ? 'selected' : '' %>>JavaScript</option>
        <option value="html" <%=locals.SelectedLanguage==='html' ? 'selected' : '' %>>HTML</option>
    </select>
</div>

<!-- Phần chứa code -->
<div class="code-container">
    <h3 class="section-title">Code:</h3>
    <div class="code-box" style="position:relative;">
        <textarea name="CodeContent" id="Code" class="form-control mt-2 codeContent"
            style="position:relative;z-index:2;background:transparent;"><%= locals.CodeContent || '' %></textarea>
        <div id="ghostLayer" aria-hidden="true"></div>
    </div>
    <div class="ai-hint-bar">
        <span class="ai-dot" id="aiDot"></span>
        <span style="font-size:0.82rem;color:#7ec8e3;font-weight:600;">AI Completion</span>
        &nbsp;·&nbsp;
        <kbd class="ai-kbd">Tab</kbd>
        <span style="font-size:0.78rem;color:#6c7a8a;">chấp nhận</span>
        &nbsp;
        <kbd class="ai-kbd">Esc</kbd>
        <span style="font-size:0.78rem;color:#6c7a8a;">bỏ qua</span>
        <button class="btn-ai-suggest" onclick="triggerAISuggest()">✦ Gợi ý ngay</button>
        <span class="ai-status" id="aiStatus">Sẵn sàng</span>
    </div>
    <div class="run-bar">
        <button class="run-button" onclick="runCode()" id="runBtn">
            <i class="fas fa-play"></i> Run
        </button>
        <button class="add-tc-button" onclick="addTestCase()" id="addTcBtn">
            <i class="fas fa-plus"></i> Thêm test case
        </button>
    </div>
</div>

<!-- Danh sách test cases -->
<div class="tc-container" id="testCaseList">
    <h3 class="section-title">Test Cases:</h3>
    <div id="tcItems">
        <div class="tc-item" data-index="0">
            <div class="tc-header">
                <span class="tc-label">Test case 1</span>
                <button class="tc-remove-btn" onclick="removeTestCase(this)" title="Xóa">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="tc-body">
                <div class="tc-col">
                    <label>Input:</label>
                    <textarea class="tc-input form-control" name="inputs[]" rows="3"
                        placeholder="Nhập input..."></textarea>
                </div>
                <div class="tc-col">
                    <label>Expected output:</label>
                    <textarea class="tc-expected form-control" name="expecteds[]" rows="3"
                        placeholder="(tuỳ chọn)"></textarea>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Kết quả -->
<div class="result-container" id="resultContainer">
    <h3 class="section-title">
        Kết quả
        <% if (locals.testcases && testcases.length> 0) { %>
            <% const passed=testcases.filter(t=> t.status === 'accepted').length;
                const total = testcases.length;
                %>
                <span class="result-summary <%= passed === total ? 'all-pass' : 'some-fail' %>">
                    <%= passed %>/<%= total %> passed
                </span>
                <% } %>
    </h3>

    <% if (locals.testcases && testcases.length> 0) { %>
        <% testcases.forEach(function(tc, i) { %>
            <% const statusMap={ accepted: { label: 'Accepted' , cls: 'status-ac' }, wrong_answer: {
                label: 'Wrong Answer' , cls: 'status-wa' }, runtime_error: { label: 'Runtime Error' , cls: 'status-re'
                }, compilation_error: { label: 'Compilation Error' , cls: 'status-ce' }, time_limit_exceeded: {
                label: 'Time Limit Exceeded' , cls: 'status-tle' }, pending: { label: 'Pending' , cls: 'status-pending'
                }, }; const s=statusMap[tc.status] || { label: tc.status, cls: 'status-pending' }; %>
                <div class="tc-result <%= s.cls %>">
                    <div class="tc-result-header" onclick="toggleResult(this)">
                        <span class="tc-result-name">Test case <%= i + 1 %></span>
                        <span class="tc-result-badge <%= s.cls %>">
                            <%= s.label %>
                        </span>
                        <% if (tc.executionTime) { %>
                            <span class="tc-result-time">
                                <%= tc.executionTime %>s
                            </span>
                            <% } %>
                                <i class="fas fa-chevron-down tc-chevron"></i>
                    </div>
                    <div class="tc-result-body">
                        <% if (tc.input) { %>
                            <div class="result-block">
                                <span class="result-block-label">Input</span>
                                <pre><%= tc.input %></pre>
                            </div>
                            <% } %>
                                <% if (tc.expected) { %>
                                    <div class="result-block">
                                        <span class="result-block-label">Expected</span>
                                        <pre><%= tc.expected %></pre>
                                    </div>
                                    <% } %>
                                        <div class="result-block">
                                            <span class="result-block-label">Output</span>
                                            <pre
                                                class="<%= tc.status === 'accepted' ? 'out-ok' : 'out-err' %>"><%= tc.output || '(không có output)' %></pre>
                                        </div>
                                        <% if (tc.errorMessage) { %>
                                            <div class="result-block">
                                                <span class="result-block-label">Error</span>
                                                <pre class="out-err"><%= tc.errorMessage %></pre>
                                            </div>
                                            <% } %>
                    </div>
                </div>
                <% }) %>
                    <% } else { %>
                        <div class="no-result">Nhấn <strong>Run</strong> để xem kết quả.</div>
                        <% } %>
</div>

<!-- Chat AI với DeepSeek/Ollama -->
<div class="chat-container">
    <div class="chat-header">
        <i class="fas fa-robot" style="color:#4f8ef7;"></i> Trợ lý AI – Hỏi về code, review, gợi ý
    </div>
    <div id="chatMessages" class="chat-messages">
        <div class="chat-message ai">💬 Xin chào! Tôi có thể giúp bạn viết code, review, gợi ý cải thiện. Hãy thử hỏi
            tôi nhé.</div>
    </div>
    <div class="chat-input-area">
        <textarea id="chatInput" rows="2"
            placeholder="Nhập câu hỏi về code, yêu cầu review hoặc sinh code..."></textarea>
        <button id="sendChatBtn" class="btn-send-chat">Gửi</button>
    </div>
</div>

