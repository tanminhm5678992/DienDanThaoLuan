<!-- CodeMirror -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.3/theme/monokai.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.3/mode/clike/clike.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.3/mode/python/python.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.3/mode/php/php.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.3/mode/htmlmixed/htmlmixed.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.3/mode/xml/xml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.3/mode/css/css.min.js"></script>

<script type="application/json"
    id="__serverData__"><%- JSON.stringify((locals.testcases || []).map(function(tc){ return { input: tc.input || '', expected: tc.expected || '' }; })) %></script>

<script>
    var cmEditor = null;
    window.__restoredTCs__ = JSON.parse(document.getElementById('__serverData__').textContent || '[]');

    var cmModeMap = {
        python: 'python',
        java: 'text/x-java',
        c: 'text/x-csrc',
        cpp: 'text/x-c++src',
        javascript: 'javascript',
        php: 'php',
        html: 'htmlmixed',
    };

    document.addEventListener('DOMContentLoaded', function () {
        var textArea = document.getElementById('Code');
        var lang = document.getElementById('languageSelect').value;
        cmEditor = CodeMirror.fromTextArea(textArea, {
            lineNumbers: true,
            theme: 'monokai',
            lineWrapping: true,
            mode: cmModeMap[lang] || 'text/plain',
        });
        setupAICompletion();
        restoreTestCases();
        toggleInput();
    });

    function restoreTestCases() {
        var restoredTCs = window.__restoredTCs__ || [];
        if (restoredTCs.length > 0) {
            document.getElementById('tcItems').innerHTML = '';
            restoredTCs.forEach(function (tc) {
                addTestCaseWithData(tc.input, tc.expected);
            });
        }
    }

    // ── AI Code Completion (Ollama) với debounce 3s, chỉ gợi ý phần tiếp theo ──
    var aiSuggestion = '';
    var aiDebounce = null;
    var aiThinking = false;
    var aiLastCode = '';

    function aiSetStatus(text, cls) {
        var el = document.getElementById('aiStatus');
        var dot = document.getElementById('aiDot');
        if (!el) return;
        el.textContent = text;
        el.className = 'ai-status ' + (cls || '');
        if (dot) dot.className = 'ai-dot ' + (cls || '');
    }

    function aiClearSuggestion() {
        aiSuggestion = '';
        var ghost = document.getElementById('ghostLayer');
        if (ghost) ghost.innerHTML = '';
        aiSetStatus('Sẵn sàng', '');
    }

    function getCurrentIndent(editor, cursor) {
        var line = editor.getLine(cursor.line);
        var indent = line.match(/^\s*/)[0];
        if (cursor.ch === 0 && line.trim() === '' && cursor.line > 0) {
            var prevLine = editor.getLine(cursor.line - 1);
            indent = prevLine.match(/^\s*/)[0];
        }
        return indent;
    }

    function processSuggestion(suggestion, editor, cursor) {
        if (!suggestion) return '';
        var codeBeforeCursor = editor.getRange({ line: 0, ch: 0 }, cursor);
        var currentLine = editor.getLine(cursor.line);
        var currentIndent = getCurrentIndent(editor, cursor);
        var sugLines = suggestion.split('\n');
        if (sugLines.length === 0) return '';
        var firstLine = sugLines[0];
        var afterCursorOnLine = currentLine.substring(cursor.ch);
        if (afterCursorOnLine.trim() !== '' && firstLine.startsWith(afterCursorOnLine)) {
            firstLine = firstLine.substring(afterCursorOnLine.length);
        }
        if (firstLine === '' && sugLines.length === 1) return '';
        var processedLines = [firstLine];
        for (var i = 1; i < sugLines.length; i++) {
            processedLines.push(currentIndent + sugLines[i]);
        }
        var processed = processedLines.join('\n');
        if (processed.trim() === '') return '';
        return processed;
    }

    function aiShowSuggestion(sug) {
        if (!cmEditor) return;
        var cursor = cmEditor.getCursor();
        var processed = processSuggestion(sug, cmEditor, cursor);
        if (!processed) {
            aiClearSuggestion();
            return;
        }
        aiSuggestion = processed;
        var code = cmEditor.getValue();
        var ghost = document.getElementById('ghostLayer');
        if (!ghost) return;
        function esc(s) {
            return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }
        ghost.innerHTML =
            '<span style="color:transparent;white-space:pre-wrap;">' + esc(code) + '</span>' +
            '<span class="ghost-suggestion">' + esc(processed) + '</span>';
        aiSetStatus('Tab để chấp nhận', 'active');
    }

    function aiAccept() {
        if (!aiSuggestion || !cmEditor) return;
        var cursor = cmEditor.getCursor();
        cmEditor.replaceRange(aiSuggestion, cursor);
        var newPos = cmEditor.getCursor();
        cmEditor.setCursor(newPos);
        aiClearSuggestion();
        aiLastCode = cmEditor.getValue();
        clearTimeout(aiDebounce);
    }

    async function triggerAISuggest() {
        if (!cmEditor) return;
        if (aiSuggestion !== '' || aiThinking) return;
        var code = cmEditor.getValue();
        var cursor = cmEditor.getCursor();
        var codeBeforeCursor = cmEditor.getRange({ line: 0, ch: 0 }, cursor);
        if (!codeBeforeCursor.trim() || codeBeforeCursor.trim().length < 5) return;
        aiThinking = true;
        aiSetStatus('AI đang suy nghĩ...', 'thinking');
        var lang = document.getElementById('languageSelect').value;
        try {
            var res = await fetch('/api/ai-suggest', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code: codeBeforeCursor, language: lang })
            });
            var data = await res.json();
            if (data.success && data.suggestion) {
                aiShowSuggestion(data.suggestion);
            } else {
                aiSetStatus(data.message || 'Không có gợi ý', '');
            }
        } catch (e) {
            aiSetStatus('Lỗi kết nối server', '');
        } finally {
            aiThinking = false;
        }
    }

    function setupAICompletion() {
        if (!cmEditor) return;
        cmEditor.on('scroll', function () {
            var ghost = document.getElementById('ghostLayer');
            var scroller = cmEditor.getScrollerElement();
            if (ghost && scroller) {
                ghost.scrollTop = scroller.scrollTop;
                ghost.scrollLeft = scroller.scrollLeft;
            }
        });
        cmEditor.on('change', function (cm, change) {
            if (change.origin === 'setValue') return;
            aiClearSuggestion();
            var code = cmEditor.getValue();
            if (code === aiLastCode) return;
            aiLastCode = code;
            clearTimeout(aiDebounce);
            aiDebounce = setTimeout(triggerAISuggest, 3000);
        });
        cmEditor.addKeyMap({
            'Tab': function (cm) {
                if (aiSuggestion) {
                    aiAccept();
                } else {
                    if (cm.somethingSelected()) {
                        cm.indentSelection('add');
                    } else {
                        cm.replaceSelection('    ', 'end');
                    }
                }
            },
            'Esc': function () {
                aiClearSuggestion();
                clearTimeout(aiDebounce);
            }
        });
    }

    // ── Các hàm xử lý test case, run code ─────────────────────────────────────
    function toggleInput() {
        var lang = document.getElementById('languageSelect').value;
        var tcContainer = document.getElementById('testCaseList');
        tcContainer.style.display = lang === 'html' ? 'none' : 'block';
        if (cmEditor) {
            cmEditor.setOption('mode', cmModeMap[lang] || 'text/plain');
        }
    }

    var tcCount = 1;
    function addTestCase() {
        addTestCaseWithData('', '');
    }
    function addTestCaseWithData(inputVal, expectedVal) {
        tcCount++;
        var list = document.getElementById('tcItems');
        var div = document.createElement('div');
        div.className = 'tc-item';
        div.setAttribute('data-index', tcCount);
        div.innerHTML =
            '<div class="tc-header">' +
            '<span class="tc-label">Test case ' + (list.children.length + 1) + '</span>' +
            '<button class="tc-remove-btn" onclick="removeTestCase(this)" title="Xóa"><i class="fas fa-times"></i></button>' +
            '</div>' +
            '<div class="tc-body">' +
            '<div class="tc-col">' +
            '<label>Input:</label>' +
            '<textarea class="tc-input form-control" name="inputs[]" rows="3" placeholder="Nhập input...">' + escapeHtml(inputVal) + '</textarea>' +
            '</div>' +
            '<div class="tc-col">' +
            '<label>Expected output:</label>' +
            '<textarea class="tc-expected form-control" name="expecteds[]" rows="3" placeholder="(tuỳ chọn)">' + escapeHtml(expectedVal) + '</textarea>' +
            '</div>' +
            '</div>';
        list.appendChild(div);
        renumberTCs();
    }
    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function (m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
    function removeTestCase(btn) {
        var item = btn.closest('.tc-item');
        var list = document.getElementById('tcItems');
        if (list.children.length <= 1) return;
        item.remove();
        renumberTCs();
    }
    function renumberTCs() {
        var items = document.querySelectorAll('#tcItems .tc-item');
        items.forEach(function (item, i) {
            item.querySelector('.tc-label').textContent = 'Test case ' + (i + 1);
        });
    }
    function runCode() {
        var language = document.getElementById('languageSelect').value;
        var sourceCode = cmEditor ? cmEditor.getValue() : document.getElementById('Code').value;
        var form = document.createElement('form');
        form.method = 'POST';
        if (language === 'html') {
            form.action = '/code/execute-html';
            appendHidden(form, 'sourceCode', sourceCode);
            appendHidden(form, 'language', language);
        } else {
            form.action = '/code/execute';
            appendHidden(form, 'language', language);
            appendHidden(form, 'sourceCode', sourceCode);
            var inputs = document.querySelectorAll('#tcItems .tc-input');
            var expecteds = document.querySelectorAll('#tcItems .tc-expected');
            inputs.forEach(function (el) {
                appendHidden(form, 'inputs[]', el.value);
            });
            expecteds.forEach(function (el) {
                appendHidden(form, 'expecteds[]', el.value);
            });
        }
        document.body.appendChild(form);
        form.submit();
    }
    function appendHidden(form, name, value) {
        var inp = document.createElement('input');
        inp.type = 'hidden';
        inp.name = name;
        inp.value = value;
        form.appendChild(inp);
    }
    function toggleResult(header) {
        header.classList.toggle('open');
        var body = header.nextElementSibling;
        body.classList.toggle('open');
    }
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.tc-result:not(.status-ac) .tc-result-header').forEach(function (h) {
            h.classList.add('open');
            h.nextElementSibling.classList.add('open');
        });
    });

    // ── Chat AI (DeepSeek/Ollama) với loading animation ──────────────────────
    const chatMessagesDiv = document.getElementById('chatMessages');
    const chatInput = document.getElementById('chatInput');
    const sendBtn = document.getElementById('sendChatBtn');
    let chatHistory = [];
    let currentTempMessageDiv = null;

    function getLoadingHtml() {
        return '<div class="loading-dots"><span>.</span><span>.</span><span>.</span></div>';
    }

    function addChatMessage(role, content, isTemp = false) {
        const msgDiv = document.createElement('div');
        msgDiv.className = `chat-message ${role}`;
        if (isTemp) {
            msgDiv.setAttribute('data-temp', 'true');
            msgDiv.innerHTML = getLoadingHtml();
        } else {
            let formatted = content.replace(/```(\w*)\n([\s\S]*?)```/g, (match, lang, code) => {
                return `<pre><code class="language-${lang || 'plaintext'}">${escapeHtml(code)}</code></pre>`;
            }).replace(/\n/g, '<br>');
            msgDiv.innerHTML = formatted;
            if (role === 'ai') {
                const codeBlocks = [...content.matchAll(/```(\w*)\n([\s\S]*?)```/g)];
                if (codeBlocks.length) {
                    codeBlocks.forEach(block => {
                        const fullCode = block[2].trim();
                        const btn = document.createElement('button');
                        btn.textContent = '📋 Chèn code này vào editor';
                        btn.className = 'btn-insert-code';
                        btn.onclick = () => {
                            if (cmEditor) {
                                cmEditor.setValue(fullCode);
                                aiClearSuggestion();
                            }
                        };
                        msgDiv.appendChild(btn);
                    });
                }
            }
        }
        chatMessagesDiv.appendChild(msgDiv);
        chatMessagesDiv.scrollTop = chatMessagesDiv.scrollHeight;
        return msgDiv;
    }

    function replaceTempMessage(finalContent, isError = false) {
        if (currentTempMessageDiv) {
            const newDiv = document.createElement('div');
            newDiv.className = 'chat-message ai';
            let formatted = finalContent.replace(/```(\w*)\n([\s\S]*?)```/g, (match, lang, code) => {
                return `<pre><code class="language-${lang || 'plaintext'}">${escapeHtml(code)}</code></pre>`;
            }).replace(/\n/g, '<br>');
            newDiv.innerHTML = formatted;
            if (!isError) {
                const codeBlocks = [...finalContent.matchAll(/```(\w*)\n([\s\S]*?)```/g)];
                if (codeBlocks.length) {
                    codeBlocks.forEach(block => {
                        const fullCode = block[2].trim();
                        const btn = document.createElement('button');
                        btn.textContent = '📋 Chèn code này vào editor';
                        btn.className = 'btn-insert-code';
                        btn.onclick = () => {
                            if (cmEditor) {
                                cmEditor.setValue(fullCode);
                                aiClearSuggestion();
                            }
                        };
                        newDiv.appendChild(btn);
                    });
                }
            }
            currentTempMessageDiv.replaceWith(newDiv);
            currentTempMessageDiv = null;
        }
    }

    async function sendChatMessage() {
        const userMsg = chatInput.value.trim();
        if (!userMsg) return;
        addChatMessage('user', userMsg);
        chatHistory.push({ role: 'user', content: userMsg });
        chatInput.value = '';
        currentTempMessageDiv = addChatMessage('ai', '', true);
        sendBtn.disabled = true;
        sendBtn.style.opacity = '0.5';
        sendBtn.style.cursor = 'not-allowed';
        try {
            const currentCode = cmEditor ? cmEditor.getValue() : '';
            const language = document.getElementById('languageSelect').value;
            const res = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    messages: chatHistory,
                    currentCode: currentCode,
                    language: language
                })
            });
            const data = await res.json();
            if (data.success) {
                const aiReply = data.reply;
                replaceTempMessage(aiReply, false);
                chatHistory.push({ role: 'assistant', content: aiReply });
            } else {
                replaceTempMessage(`❌ Lỗi: ${data.error || 'Không thể kết nối AI'}`, true);
            }
        } catch (err) {
            replaceTempMessage(`❌ Lỗi kết nối: ${err.message}`, true);
        } finally {
            sendBtn.disabled = false;
            sendBtn.style.opacity = '1';
            sendBtn.style.cursor = 'pointer';
            currentTempMessageDiv = null;
        }
    }

    sendBtn.addEventListener('click', sendChatMessage);
    chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && !e.shiftKey && !sendBtn.disabled) {
            e.preventDefault();
            sendChatMessage();
        }
    });
</script>

