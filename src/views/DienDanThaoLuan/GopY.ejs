<style>
    .gopy-wrap {
        max-width: 640px;
        margin: 2rem auto;
    }

    .gopy-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }

    .gopy-card-header {
        background: rgba(99, 179, 237, 0.06);
        border-bottom: 1px solid var(--border);
        padding: 1rem 1.4rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .gopy-card-header i {
        color: var(--accent);
        font-size: 1rem;
    }

    .gopy-card-header h4 {
        font-family: var(--mono);
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }

    .gopy-card-body {
        padding: 1.4rem;
    }

    .gopy-card-body label {
        font-size: 0.82rem;
        color: var(--text-muted);
        font-weight: 500;
        margin-bottom: 6px;
        display: block;
        font-family: var(--mono);
    }

    .gopy-textarea {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-primary);
        font-size: 0.88rem;
        padding: 0.75rem 1rem;
        resize: vertical;
        font-family: var(--sans);
        transition: border-color 0.2s;
        min-height: 140px;
        line-height: 1.6;
    }

    .gopy-textarea:focus {
        outline: none;
        border-color: var(--accent);
        background: rgba(99, 179, 237, 0.04);
    }

    .gopy-textarea::placeholder {
        color: var(--text-muted);
        opacity: 0.6;
    }

    .char-count {
        text-align: right;
        font-size: 0.72rem;
        color: var(--text-muted);
        font-family: var(--mono);
        margin-top: 4px;
    }

    .btn-send-gopy {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--accent);
        color: #0b0f1a;
        border: none;
        padding: 0.55rem 1.3rem;
        border-radius: 9px;
        font-size: 0.86rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        font-family: var(--sans);
    }

    .btn-send-gopy:hover {
        background: #90cdf4;
        transform: translateY(-1px);
    }

    .alert-success-custom {
        background: rgba(104, 211, 145, 0.1);
        border: 1px solid rgba(104, 211, 145, 0.25);
        color: var(--accent2);
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .alert-error-custom {
        background: rgba(252, 78, 78, 0.08);
        border: 1px solid rgba(252, 78, 78, 0.2);
        color: #fc4e4e;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .gopy-note {
        background: rgba(246, 173, 85, 0.06);
        border: 1px solid rgba(246, 173, 85, 0.15);
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.8rem;
        color: var(--accent3);
        margin-bottom: 1rem;
        display: flex;
        gap: 8px;
        align-items: flex-start;
    }

    .gopy-note i {
        flex-shrink: 0;
        margin-top: 2px;
    }
</style>

<div class="gopy-wrap">
    <div class="gopy-card">
        <div class="gopy-card-header">
            <i class="fas fa-comment-dots"></i>
            <h4>Góp ý & Phản hồi</h4>
        </div>
        <div class="gopy-card-body">

            <!-- Thông báo -->
            <% if (locals.thongBao) { %>
                <div class="alert-success-custom">
                    <i class="fas fa-check-circle"></i>
                    <%= thongBao %>
                </div>
                <% } %>
                    <% if (locals.Loi) { %>
                        <div class="alert-error-custom">
                            <i class="fas fa-exclamation-circle"></i>
                            <%= Loi %>
                        </div>
                        <% } %>

                            <div class="gopy-note">
                                <i class="fas fa-info-circle"></i>
                                <span>Góp ý của bạn sẽ được gửi đến quản trị viên để cải thiện diễn đàn. Vui lòng góp ý
                                    lịch sự và mang tính xây dựng.</span>
                            </div>

                            <form action="/gop-y" method="POST">
                                <div class="mb-3">
                                    <label for="feedback-content">Nội dung góp ý</label>
                                    <textarea id="feedback-content" name="NoiDung" class="gopy-textarea" rows="6"
                                        placeholder="Chia sẻ ý kiến, báo lỗi, hoặc đề xuất tính năng mới..."
                                        maxlength="1000"
                                        oninput="document.getElementById('charCount').textContent = this.value.length"></textarea>
                                    <div class="char-count"><span id="charCount">0</span> / 1000</div>
                                </div>
                                <div class="d-flex justify-content-end">
                                    <button type="submit" class="btn-send-gopy">
                                        <i class="fas fa-paper-plane"></i> Gửi góp ý
                                    </button>
                                </div>
                            </form>
        </div>
    </div>
</div>