<style>
    .chude-header {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem 1.3rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .chude-header-icon {
        width: 40px;
        height: 40px;
        background: rgba(99, 179, 237, 0.1);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: var(--accent);
    }

    .chude-header h4 {
        font-family: var(--mono);
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }

    .chude-header small {
        color: var(--text-muted);
        font-size: 0.78rem;
    }

    .chude-list-wrap {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
    }

    .chude-item {
        display: flex;
        align-items: center;
        padding: 0.85rem 1.2rem;
        border-bottom: 1px solid var(--border);
        text-decoration: none;
        color: var(--text-primary);
        transition: background 0.15s;
        gap: 12px;
    }

    .chude-item:last-child {
        border-bottom: none;
    }

    .chude-item:hover {
        background: rgba(99, 179, 237, 0.04);
        text-decoration: none;
        color: var(--text-primary);
    }

    .chude-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
        flex-shrink: 0;
        box-shadow: 0 0 6px rgba(99, 179, 237, 0.5);
    }

    .chude-name {
        flex: 1;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-primary);
        transition: color 0.15s;
    }

    .chude-item:hover .chude-name {
        color: var(--accent);
    }

    .chude-badge {
        background: rgba(104, 211, 145, 0.1);
        border: 1px solid rgba(104, 211, 145, 0.2);
        color: var(--accent2);
        font-size: 0.72rem;
        font-family: var(--mono);
        padding: 2px 9px;
        border-radius: 20px;
        flex-shrink: 0;
    }

    .chude-arrow {
        color: var(--text-muted);
        font-size: 0.75rem;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .chude-item:hover .chude-arrow {
        opacity: 1;
    }
</style>

<!-- Breadcrumb -->
<nav class="mt-3 mb-2" aria-label="breadcrumb">
    <ol class="breadcrumb" style="background:none;padding:0;margin:0;font-size:0.82rem;">
        <li class="breadcrumb-item"><a href="/" style="color:var(--text-muted);text-decoration:none;">Trang chủ</a></li>
        <li class="breadcrumb-item active" style="color:var(--accent);font-family:var(--mono);">
            <%= typeof TenLoai !=='undefined' ? TenLoai : 'Chủ đề' %>
        </li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-8">
        <!-- Header loại chủ đề -->
        <div class="chude-header">
            <div class="chude-header-icon"><i class="fas fa-layer-group"></i></div>
            <div>
                <h4>
                    <%= typeof TenLoai !=='undefined' ? TenLoai : 'Chủ đề' %>
                </h4>
                <small>
                    <%= chuDes ? chuDes.length : 0 %> chủ đề
                </small>
            </div>
        </div>

        <!-- Danh sách chủ đề -->
        <div class="chude-list-wrap">
            <% if (!chuDes || chuDes.length===0) { %>
                <div style="text-align:center;padding:2.5rem;color:var(--text-muted);">
                    <i class="fas fa-inbox" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:0.7rem;"></i>
                    <p style="font-size:0.88rem;margin:0;">Chưa có chủ đề nào.</p>
                </div>
                <% } else { %>
                    <% chuDes.forEach(function(cd) { %>
                        <a href="/bai-viet-theo-chu-de/<%= cd.MaCD %>?tenloai=<%= encodeURIComponent(cd.TenLoai || '') %>"
                            class="chude-item">
                            <span class="chude-dot"></span>
                            <span class="chude-name">
                                <%= cd.TenCD %>
                            </span>
                            <span class="chude-badge"><i class="fas fa-file-alt me-1"></i>
                                <%= cd.SoBai %> bài
                            </span>
                            <i class="fas fa-chevron-right chude-arrow"></i>
                        </a>
                        <% }); %>
                            <% } %>
        </div>

        <!-- Phân trang -->
        <% if (locals.totalPages && totalPages> 1) { %>
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <% for (let i=1; i <=totalPages; i++) { %>
                        <li class="page-item <%= currentPage == i ? 'active' : '' %>">
                            <a class="page-link" href="/chu-de/<%= MaLoai %>?page=<%= i %>">
                                <%= i %>
                            </a>
                        </li>
                        <% } %>
                </ul>
            </nav>
            <% } %>
    </div>

    <div class="col-lg-4">
        <%- include('../Shared/_PartialQTV') %>
    </div>
</div>