<style>
    .admin {
        background-color: #e7f3ff;
        border-left: 2px solid #007bff;
        padding: 15px;
        margin-bottom: 15px;
        box-shadow: 0 2px 10px rgba(0, 123, 255, 0.3);
        border-radius: 5px;
    }
</style>

<div class="row my-5">
    <!-- Left Column -->
    <div class="col-md-8">
        <div class="flex-grow-1 me-3 bg-white p-2 rounded">
            <div class="d-flex justify-content-end mb-2">
                <h2 style="font-weight: bold; margin-right: auto; margin-left: 5px; color: gray">Bài viết mới</h2>
                <div class="me-2">
                    <button onclick="location.href='/them-bai-viet'" class="btn btn-primary">Thêm bài</button>
                </div>
                <div>
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle" type="button"
                            data-bs-toggle="dropdown">Lọc</button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/loc?sortOrder=newest&isAllPosts=true">Mới nhất</a></li>
                            <li><a class="dropdown-item" href="/loc?sortOrder=oldest&isAllPosts=true">Lâu nhất</a></li>
                            <li><a class="dropdown-item" href="/loc?sortOrder=az&isAllPosts=true">Tiêu đề bài viết từ
                                    A-Z</a></li>
                            <li><a class="dropdown-item" href="/loc?sortOrder=za&isAllPosts=true">Tiêu đề bài viết từ
                                    Z-A</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Post Items -->
            <% if (baiViets && baiViets.length> 0) { %>
                <% baiViets.forEach(function(t) { %>
                    <div class="mb-1 rounded-0 border-top pt-3 <%= t.IsAdmin ? 'admin' : '' %>">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div class="d-flex align-items-center">
                                    <img src="/Images/<%= t.AnhDaiDien || 'avatar.jpg' %>" alt="User Avatar"
                                        class="img-fluid rounded-circle" width="50">
                                    <div class="ms-3">
                                        <h5 class="card-title mb-1">
                                            <a href="/bai-viet/<%= t.MaBV %>" class="text-decoration-none text-dark">
                                                <%= t.TieuDe %>
                                            </a>
                                        </h5>
                                        <p class="text-muted">
                                            <%= t.TenNguoiViet %>
                                        </p>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <p class="mb-1">Ngày đăng: <span class="text-muted">
                                            <%= t.NgayDang %>
                                        </span></p>
                                    <p class="mb-0">Trả lời: <span class="text-muted">
                                            <%= t.SoBL %>
                                        </span></p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                        <% } %>
        </div>

        <!-- Phân trang -->
        <% if (locals.totalPages && totalPages> 1) { %>
            <nav class="MenuTrang mt-3">
                <ul class="pagination justify-content-center">
                    <% for (let i=1; i <=totalPages; i++) { %>
                        <li class="page-item <%= currentPage == i ? 'active' : '' %>">
                            <a class="page-link" href="/bai-viet-moi?page=<%= i %>">
                                <%= i %>
                            </a>
                        </li>
                        <% } %>
                </ul>
            </nav>
            <% } %>
    </div>

    <!-- Right Column -->
    <div class="col-md-4">
        <%- include('../Shared/_PartialQTV') %>
    </div>
</div>