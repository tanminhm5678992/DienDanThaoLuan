<% if (locals.successMessage) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= successMessage %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>
        <% if (locals.errorMessage) { %>
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <%= errorMessage %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

                <h2 class="text-center mb-4 mt-4">Gửi Thông Báo Chung</h2>

                <div class="container" style="max-width:700px;">
                    <div class="card p-4 shadow-sm">
                        <form action="/admin/thong-bao-tong" method="POST">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Loại chủ đề (tùy chọn):</label>
                                <select name="MaLoai" class="form-select">
                                    <option value="">-- Gửi đến tất cả thành viên --</option>
                                    <% if (loaiCDs && loaiCDs.length> 0) { %>
                                        <% loaiCDs.forEach(function(l) { %>
                                            <option value="<%= l.MaLoai %>">
                                                <%= l.TenLoai %>
                                            </option>
                                            <% }); } %>
                                </select>
                                <small class="text-muted">Hiện tại hệ thống gửi đến tất cả thành viên.</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Nội dung thông báo:</label>
                                <textarea name="NoiDung" class="form-control" rows="5"
                                    placeholder="Nhập nội dung thông báo gửi đến tất cả thành viên..."
                                    required></textarea>
                            </div>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary px-4">Gửi thông báo</button>
                            </div>
                        </form>
                    </div>
                </div>