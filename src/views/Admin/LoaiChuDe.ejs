<% if (locals.successMessage) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= successMessage %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>
        <% if (locals.errorMessage) { %>
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <%= errorMessage %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

                <h2 style="text-align:center" class="p-2">QUẢN LÝ LOẠI CHỦ ĐỀ</h2>

                <!-- Form thêm mới -->
                <div class="card p-3 mb-3 shadow-sm">
                    <h6 class="fw-bold mb-2">Thêm loại chủ đề mới</h6>
                    <form action="/admin/quan-ly/loai-chu-de/them" method="POST" class="row g-2 align-items-end">
                        <div class="col-md-8">
                            <input type="text" name="TenLoai" class="form-control" placeholder="Nhập tên loại chủ đề..."
                                required>
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary w-100">+ Tạo mới</button>
                        </div>
                    </form>
                </div>

                <!-- Bảng danh sách -->
                <div style="background-color:white; border-radius:15px; box-shadow: inset 0 0 5px rgba(0,0,0,0.1);">
                    <table class="table table-striped table-bordered mb-0">
                        <thead>
                            <tr>
                                <th style="text-align:center; width:80px;">STT</th>
                                <th>Tên loại chủ đề</th>
                                <th style="text-align:center; width:180px;">Tùy chỉnh</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (loaiCDs && loaiCDs.length> 0) { %>
                                <% loaiCDs.forEach(function(item, idx) { %>
                                    <tr>
                                        <td style="text-align:center;">
                                            <%= idx + 1 %>
                                        </td>

                                        <%# Ô tên %>
                                            <td style="vertical-align:middle;">
                                                <%# Chế độ xem - mặc định hiện %>
                                                    <span id="label-<%= item.MaLoai %>">
                                                        <%= item.TenLoai %>
                                                    </span>

                                                    <%# Chế độ sửa - ẩn mặc định %>
                                                        <form id="form-<%= item.MaLoai %>"
                                                            action="/admin/quan-ly/loai-chu-de/sua/<%= item.MaLoai %>"
                                                            method="POST" style="display:none;">
                                                            <input type="text" name="TenLoai"
                                                                id="input-<%= item.MaLoai %>"
                                                                class="form-control form-control-sm"
                                                                value="<%= item.TenLoai %>" required>
                                                        </form>
                                            </td>

                                            <%# Ô nút %>
                                                <td style="text-align:center; vertical-align:middle;">
                                                    <%# Nút Sửa + Xóa: hiện mặc định %>
                                                        <div id="btns-view-<%= item.MaLoai %>">
                                                            <button class="btn btn-warning btn-sm"
                                                                onclick="batDauSua('<%= item.MaLoai %>')">Sửa</button>
                                                            <form
                                                                action="/admin/quan-ly/loai-chu-de/xoa/<%= item.MaLoai %>"
                                                                method="POST" style="display:inline"
                                                                onsubmit="return confirm('Xóa loại chủ đề này?')">
                                                                <button type="submit"
                                                                    class="btn btn-danger btn-sm">Xóa</button>
                                                            </form>
                                                        </div>

                                                        <%# Nút Lưu + Hủy: ẩn mặc định %>
                                                            <div id="btns-edit-<%= item.MaLoai %>"
                                                                style="display:none;">
                                                                <button type="button" class="btn btn-success btn-sm"
                                                                    onclick="luuSua('<%= item.MaLoai %>')">Lưu</button>
                                                                <button type="button" class="btn btn-secondary btn-sm"
                                                                    onclick="huyySua('<%= item.MaLoai %>')">Hủy</button>
                                                            </div>
                                                </td>
                                    </tr>
                                    <% }); %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="3" class="text-center text-muted">Chưa có loại chủ đề nào.
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>

                <script>
                    function batDauSua(maLoai) {
                        // Đóng tất cả dòng đang mở
                        document.querySelectorAll('[id^="btns-edit-"]').forEach(function (el) {
                            if (el.style.display !== 'none') {
                                var id = el.id.replace('btns-edit-', '');
                                _dongSua(id);
                            }
                        });

                        // Mở dòng này
                        document.getElementById('label-' + maLoai).style.display = 'none';
                        document.getElementById('form-' + maLoai).style.display = 'block';
                        document.getElementById('btns-view-' + maLoai).style.display = 'none';
                        document.getElementById('btns-edit-' + maLoai).style.display = 'block';
                        document.getElementById('input-' + maLoai).focus();
                    }

                    function luuSua(maLoai) {
                        document.getElementById('form-' + maLoai).submit();
                    }

                    function huyySua(maLoai) {
                        var label = document.getElementById('label-' + maLoai);
                        document.getElementById('input-' + maLoai).value = label.textContent.trim();
                        _dongSua(maLoai);
                    }

                    function _dongSua(maLoai) {
                        document.getElementById('label-' + maLoai).style.display = 'inline';
                        document.getElementById('form-' + maLoai).style.display = 'none';
                        document.getElementById('btns-view-' + maLoai).style.display = 'block';
                        document.getElementById('btns-edit-' + maLoai).style.display = 'none';
                    }
                </script>