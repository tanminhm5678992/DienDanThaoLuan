<% if (locals.successMessage) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= successMessage %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

        <div class="container mt-5 mb-5">
            <h2 class="text-primary mb-4 text-center">Quản Lý Thành Viên</h2>

            <!-- Tìm kiếm + sắp xếp -->
            <div class="mb-4 d-flex align-items-center gap-3 flex-wrap">
                <form action="/admin/quan-ly-thanh-vien" method="GET" class="d-inline-flex" style="width:50%;">
                    <div class="input-group w-100">
                        <input type="text" name="search" class="form-control"
                            placeholder="Tìm kiếm theo tên đăng nhập..." value="<%= locals.searchInput || '' %>">
                        <button class="btn btn-primary rounded-end" type="submit" style="min-width:100px;">Tìm
                            kiếm</button>
                    </div>
                </form>
                <div class="ms-auto" style="width:220px;">
                    <select class="form-select" onchange="location = this.value;">
                        <option value="/admin/quan-ly-thanh-vien?sort=namea-z" <%=(locals.sortOrder==='namea-z'
                            )?'selected':'' %>>Tên (A-Z)</option>
                        <option value="/admin/quan-ly-thanh-vien?sort=namez-a" <%=(locals.sortOrder==='namez-a'
                            )?'selected':'' %>>Tên (Z-A)</option>
                        <option value="/admin/quan-ly-thanh-vien?sort=datenew" <%=(locals.sortOrder==='datenew'
                            )?'selected':'' %>>Ngày tham gia (Mới nhất)</option>
                        <option value="/admin/quan-ly-thanh-vien?sort=dateold" <%=(locals.sortOrder==='dateold'
                            )?'selected':'' %>>Ngày tham gia (Lâu nhất)</option>
                    </select>
                </div>
            </div>

            <p>Số lượng thành viên: <strong>
                    <%= thanhViens ? thanhViens.length : 0 %>
                </strong></p>

            <% if (thanhViens && thanhViens.length> 0) { %>
                <div class="row" id="memberList">
                    <% thanhViens.forEach(function(member) { %>
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="card border-0 shadow-sm rounded h-100">
                                <img src="/Images/<%= member.AnhDaiDien || 'avatar.jpg' %>" alt="Avatar"
                                    class="card-img-top img-fluid mt-2"
                                    style="border-radius:50px; width:100px; height:100px; object-fit:cover; margin:0 auto;"
                                    onerror="this.src='/Images/default.png'">
                                <div class="card-body text-center">
                                    <h5 class="card-title">
                                        <%= member.TenDangNhap %>
                                    </h5>
                                    <% if (member.TrangThai===false || member.TrangThai===0) { %>
                                        <p class="text-danger small"><i class="bi bi-lock-fill"></i> Tài khoản đã bị
                                            khóa</p>
                                        <% } %>
                                            <p class="text-muted member-fullname">
                                                <%= member.HoTen || 'N/A' %>
                                            </p>
                                            <p class="text-muted small">Email: <%= member.Email || 'N/A' %>
                                            </p>
                                            <p class="text-muted small">Giới tính: <%= member.GioiTinh || 'N/A' %>
                                            </p>
                                            <p class="text-muted small">
                                                Ngày sinh: <%= member.NgaySinh ? new
                                                    Date(member.NgaySinh).toLocaleDateString('vi-VN') : 'N/A' %>
                                            </p>
                                            <p class="text-muted small">
                                                Tham gia: <%= member.NgayThamGia ? new
                                                    Date(member.NgayThamGia).toLocaleDateString('vi-VN') : 'N/A' %>
                                            </p>
                                            <div class="mt-3 d-flex gap-2 justify-content-center">
                                                <% if (member.TrangThai===false || member.TrangThai===0) { %>
                                                    <button class="btn btn-success"
                                                        onclick="confirmUnlock('/admin/mo-khoa-thanh-vien/<%= member.MaTV %>', '<%= member.TenDangNhap %>')">
                                                        Mở Khóa
                                                    </button>
                                                    <% } else { %>
                                                        <button class="btn btn-danger"
                                                            onclick="confirmLock('/admin/khoa-thanh-vien/<%= member.MaTV %>', '<%= member.TenDangNhap %>')">
                                                            Khóa Tài Khoản
                                                        </button>
                                                        <% } %>
                                            </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
                <% } else { %>
                    <p class="text-muted text-center">Không có thành viên nào.</p>
                    <% } %>
        </div>

        <!-- Modal xác nhận khóa -->
        <div id="overlay"
            style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:999;">
        </div>
        <div id="confirmModal" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
    background:#fff; padding:30px; border-radius:10px; z-index:1000; max-width:400px; width:90%; text-align:center;">
            <h3>Xác Nhận Khóa Tài Khoản</h3>
            <p style="font-size:18px;">Bạn có chắc chắn muốn khóa tài khoản <strong id="lockUsername"></strong>?</p>
            <button id="confirmButton" class="btn btn-danger mb-2 w-100">Khóa Tài Khoản</button>
            <button class="btn btn-secondary w-100" onclick="closeModal()">Hủy</button>
        </div>

        <!-- Modal xác nhận mở khóa -->
        <div id="unlockModal" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
    background:#fff; padding:30px; border-radius:10px; z-index:1000; max-width:400px; width:90%; text-align:center;">
            <h3>Xác Nhận Mở Khóa</h3>
            <p style="font-size:18px;">Bạn có chắc chắn muốn mở khóa tài khoản <strong id="unlockUsername"></strong>?
            </p>
            <button id="unlockConfirmButton" class="btn btn-success mb-2 w-100">Mở Khóa Tài Khoản</button>
            <button class="btn btn-secondary w-100" onclick="closeModal()">Hủy</button>
        </div>

        <style>
            .card {
                transition: transform 0.2s;
            }

            .card:hover {
                transform: scale(1.03);
            }

            .card-title {
                font-weight: bold;
                color: #0c88c2;
            }

            .member-fullname {
                font-weight: bold;
                font-size: 1.05rem;
                color: #ff5733;
            }
        </style>

        <script>
            let actionUrl = '';
            function confirmLock(url, username) {
                actionUrl = url;
                document.getElementById('lockUsername').textContent = username || 'này';
                document.getElementById("overlay").style.display = "block";
                document.getElementById('confirmModal').style.display = 'block';
            }
            function confirmUnlock(url, username) {
                actionUrl = url;
                document.getElementById('unlockUsername').textContent = username || 'này';
                document.getElementById("overlay").style.display = "block";
                document.getElementById('unlockModal').style.display = 'block';
            }
            function closeModal() {
                document.getElementById("overlay").style.display = "none";
                document.getElementById('confirmModal').style.display = 'none';
                document.getElementById('unlockModal').style.display = 'none';
            }
            function submitAction() {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = actionUrl;
                document.body.appendChild(form);
                form.submit();
            }
            document.getElementById('confirmButton').onclick = submitAction;
            document.getElementById('unlockConfirmButton').onclick = submitAction;
        </script>