<% if (locals.successMessage) { %>
    <div class="alert alert-success alert-dismissible fade show mx-3 mt-3" role="alert">
        <%= successMessage %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>
        <% if (locals.errorMessage) { %>
            <div class="alert alert-danger alert-dismissible fade show mx-3 mt-3" role="alert">
                <%= errorMessage %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

                <div class="list-group m-3 pt-2 pb-2">
                    <% if (!baiViets || baiViets.length===0) { %>
                        <div class="alert alert-warning">Không có bài viết chờ duyệt nào.</div>
                        <% } else { %>
                            <% baiViets.forEach(function(bv) { %>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">
                                            <i class="fas fa-user-circle me-1 text-muted"></i>
                                            <strong>
                                                <%= bv.ThanhVien ? bv.ThanhVien.TenDangNhap : 'Không rõ' %>
                                            </strong>
                                            vừa mới gửi một bài viết:
                                        </h6>
                                        <h6><i>"<%= bv.TieuDeBV %>"</i></h6>
                                        <small class="text-muted">
                                            Chủ đề: <%= bv.ChuDe ? bv.ChuDe.TenCD : 'N/A' %> &nbsp;|&nbsp;
                                                Lúc <%= bv.NgayDang ? new Date(bv.NgayDang).toLocaleString('vi-VN')
                                                    : 'N/A' %>
                                        </small>
                                    </div>
                                    <div class="d-flex gap-2 flex-wrap justify-content-end">
                                        <a href="/admin/chi-tiet-bai/<%= bv.MaBV %>"
                                            class="btn btn-primary btn-sm rounded-pill">Chi tiết</a>

                                        <%# Duyệt: POST form thông thường — không cần modal %>
                                            <form action="/admin/duyet-bai/<%= bv.MaBV %>" method="POST"
                                                style="display:inline">
                                                <button type="submit" class="btn btn-success btn-sm rounded-pill">✓
                                                    Duyệt</button>
                                            </form>

                                            <%# Từ chối: mở inline form ngay trong card, tránh vấn đề modal %>
                                                <button type="button" class="btn btn-danger btn-sm rounded-pill"
                                                    onclick="toggleTuChoi('<%= bv.MaBV %>', this)">✗ Từ chối</button>
                                    </div>
                                </div>

                                <%# Form từ chối inline — ẩn mặc định, hiện khi bấm nút %>
                                    <div id="form-tuchoi-<%= bv.MaBV %>" class="list-group-item bg-light"
                                        style="display:none;">
                                        <form action="/admin/tu-choi-bai/<%= bv.MaBV %>" method="POST">
                                            <label class="form-label fw-bold mb-1">Lý do từ chối:</label>
                                            <textarea name="lydo" class="form-control mb-2" rows="2"
                                                placeholder="Nhập lý do từ chối..." required></textarea>
                                            <div class="d-flex gap-2">
                                                <button type="submit" class="btn btn-danger btn-sm">Xác nhận từ
                                                    chối</button>
                                                <button type="button" class="btn btn-secondary btn-sm"
                                                    onclick="toggleTuChoi('<%= bv.MaBV %>', null)">Hủy</button>
                                            </div>
                                        </form>
                                    </div>
                                    <% }); %>
                                        <% } %>

                                            <!-- Phân trang -->
                                            <% if (totalPages> 1) { %>
                                                <nav class="mt-3">
                                                    <ul class="pagination justify-content-center">
                                                        <% for(let i=1; i <=totalPages; i++) { %>
                                                            <li
                                                                class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                                <a class="page-link" href="?page=<%= i %>">
                                                                    <%= i %>
                                                                </a>
                                                            </li>
                                                            <% } %>
                                                    </ul>
                                                </nav>
                                                <% } %>
                </div>

                <script>
                    function toggleTuChoi(maBV, btnEl) {
                        const formDiv = document.getElementById('form-tuchoi-' + maBV);
                        const isHidden = formDiv.style.display === 'none';

                        // Đóng tất cả form từ chối khác trước
                        document.querySelectorAll('[id^="form-tuchoi-"]').forEach(el => {
                            el.style.display = 'none';
                        });

                        if (isHidden) {
                            formDiv.style.display = 'block';
                            // Focus vào textarea
                            formDiv.querySelector('textarea').focus();
                        }
                    }
                </script>