<!DOCTYPE html>
<html lang="vi">

<head>
    <title>Quên mật khẩu - IT Xperience</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --border: rgba(255, 255, 255, 0.08);
            --accent: #4f8ef7;
            --accent2: #a78bfa;
            --text: #f0f0f5;
            --muted: #6b7280;
            --error: #f87171;
            --success: #34d399;
            --input-bg: rgba(255, 255, 255, 0.04);
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Space Grotesk', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(79, 142, 247, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(79, 142, 247, 0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

        .container-center {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
            animation: drift 12s ease-in-out infinite;
        }

        .orb-1 {
            width: 400px;
            height: 400px;
            background: rgba(79, 142, 247, 0.12);
            top: -100px;
            left: -100px;
        }

        .orb-2 {
            width: 300px;
            height: 300px;
            background: rgba(167, 139, 250, 0.1);
            bottom: -80px;
            right: -80px;
            animation-delay: -6s;
        }

        @keyframes drift {

            0%,
            100% {
                transform: translate(0, 0);
            }

            50% {
                transform: translate(30px, 20px);
            }
        }

        .card {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 400px;
            padding: 2.5rem;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            box-shadow: 0 0 60px rgba(79, 142, 247, 0.08), 0 20px 60px rgba(0, 0, 0, 0.5);
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .icon-wrap {
            display: flex;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .icon-circle {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(79, 142, 247, 0.2), rgba(167, 139, 250, 0.2));
            border: 1px solid rgba(79, 142, 247, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: var(--accent);
        }

        h3 {
            text-align: center;
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .subtitle {
            text-align: center;
            color: var(--muted);
            font-size: 0.88rem;
            margin-bottom: 1.8rem;
            line-height: 1.5;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-group input {
            width: 100%;
            padding: 0.85rem 1rem;
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .form-group input::placeholder {
            color: var(--muted);
        }

        .form-group input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(79, 142, 247, 0.12);
        }

        .form-group input:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .btn-submit {
            width: 100%;
            padding: 0.9rem;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border: none;
            border-radius: 10px;
            color: #fff;
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            letter-spacing: 0.05em;
            transition: opacity 0.2s, transform 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-submit:hover:not(:disabled) {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .btn-submit:active:not(:disabled) {
            transform: translateY(0);
        }

        .btn-submit:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        #message {
            font-size: 0.85rem;
            text-align: center;
            margin: 0.8rem 0;
            min-height: 1.2em;
            padding: 0.6rem;
            border-radius: 8px;
            display: none;
        }

        #message.success {
            color: var(--success);
            background: rgba(52, 211, 153, 0.08);
            border: 1px solid rgba(52, 211, 153, 0.2);
            display: block;
        }

        #message.error {
            color: var(--error);
            background: rgba(248, 113, 113, 0.08);
            border: 1px solid rgba(248, 113, 113, 0.2);
            display: block;
        }

        .countdown {
            display: none;
            text-align: center;
            font-size: 0.82rem;
            color: var(--muted);
            margin-bottom: 0.5rem;
            padding: 0.5rem;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 8px;
        }

        .countdown span {
            color: var(--accent);
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
        }

        .divider {
            text-align: center;
            color: var(--muted);
            font-size: 0.82rem;
            margin: 1.2rem 0;
            position: relative;
        }

        .divider::before,
        .divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 30%;
            height: 1px;
            background: var(--border);
        }

        .divider::before {
            left: 0;
        }

        .divider::after {
            right: 0;
        }

        .signin-link {
            display: block;
            text-align: center;
            padding: 0.8rem;
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: border-color 0.2s, background 0.2s;
        }

        .signin-link:hover {
            border-color: var(--accent);
            background: rgba(79, 142, 247, 0.06);
            color: var(--accent);
        }

        .marquee-inner p {
            color: rgba(255, 255, 255, 0.85);
        }

        .back-link {
            position: fixed;
            top: 1.5rem;
            left: 1.5rem;
            z-index: 20;
            color: var(--muted);
            text-decoration: none;
            font-size: 0.88rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: color 0.2s;
        }

        .back-link:hover {
            color: var(--accent);
        }
    </style>
</head>

<body>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <a href="/" class="back-link"><i class="fa fa-arrow-left"></i> Quay lại</a>

    <div class="container-center">
        <div class="card">
            <div class="icon-wrap">
                <div class="icon-circle">
                    <i class="fa fa-lock"></i>
                </div>
            </div>
            <h3>Forgot Password</h3>
            <p class="subtitle">Nhập email của bạn và chúng tôi sẽ gửi mật khẩu mới.</p>

            <form id="forgotPasswordForm">
                <div class="form-group">
                    <input type="email" name="email" id="email" placeholder="Email của bạn" required>
                </div>
                <div id="countdown" class="countdown">
                    Vui lòng chờ <span id="timer">30</span> giây trước khi gửi lại.
                </div>
                <div id="message"></div>
                <button type="submit" class="btn-submit" id="submitButton">
                    <i class="fa fa-paper-plane"></i> Gửi yêu cầu
                </button>
            </form>

            <div class="divider">Đã có mật khẩu mới?</div>
            <a href="/account/login" class="signin-link">Quay lại đăng nhập →</a>
        </div>
    </div>

    <script>
        (function () {
            var remainingTime = 0;
            var countdownEl = document.getElementById('countdown');
            var timerEl = document.getElementById('timer');
            var submitBtn = document.getElementById('submitButton');
            var messageEl = document.getElementById('message');

            function updateTimer() {
                if (remainingTime > 0) {
                    timerEl.textContent = remainingTime;
                    remainingTime--;
                    submitBtn.disabled = true;
                    countdownEl.style.display = 'block';
                    setTimeout(updateTimer, 1000);
                } else {
                    submitBtn.disabled = false;
                    countdownEl.style.display = 'none';
                }
            }

            document.getElementById('forgotPasswordForm').addEventListener('submit', function (e) {
                e.preventDefault();
                submitBtn.disabled = true;
                messageEl.className = '';
                messageEl.textContent = '';

                fetch('/account/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: document.getElementById('email').value })
                })
                    .then(function (r) { return r.json(); })
                    .then(function (response) {
                        messageEl.textContent = response.message;
                        if (response.success) {
                            messageEl.className = 'success';
                            remainingTime = response.remainingTime || 30;
                            updateTimer();
                        } else if (response.remainingTime) {
                            messageEl.className = 'error';
                            remainingTime = response.remainingTime;
                            updateTimer();
                        } else {
                            messageEl.className = 'error';
                            submitBtn.disabled = false;
                        }
                    })
                    .catch(function () {
                        messageEl.textContent = 'Có lỗi xảy ra. Vui lòng thử lại sau.';
                        messageEl.className = 'error';
                        submitBtn.disabled = false;
                    });
            });
        })();
    </script>
</body>

</html>